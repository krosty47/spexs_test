{
  "name": "workflow-manager",
  "version": "0.6.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "db:generate": "pnpm --filter @workflow-manager/prisma db:generate",
    "db:push": "pnpm --filter @workflow-manager/prisma db:push",
    "db:seed": "pnpm --filter @workflow-manager/prisma db:seed",
    "db:migrate": "pnpm --filter @workflow-manager/prisma db:migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.2.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  }
}
