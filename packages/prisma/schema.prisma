generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum Role {
  ADMIN
  USER
}

enum EventStatus {
  OPEN
  RESOLVED
  SNOOZED
}

enum TriggerType {
  THRESHOLD
  VARIANCE
}

enum EventAction {
  CREATED
  TRIGGERED
  RESOLVED
  SNOOZED
  REOPENED
}

enum NotificationType {
  EVENT_TRIGGERED
  EVENT_RESOLVED
  EVENT_SNOOZED
  EVENT_REOPENED
}

// --- Models ---

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workflows      Workflow[]
  comments       Comment[]
  snoozes        Snooze[]
  eventHistory   EventHistory[]
  resolvedEvents Event[] @relation("ResolvedByUser")
  notifications  Notification[]

  @@map("users")
}

model Workflow {
  id            String       @id @default(cuid())
  name          String
  description   String?
  isActive      Boolean      @default(false) @map("is_active")
  triggerType   TriggerType? @map("trigger_type")
  triggerConfig Json?        @map("trigger_config")
  outputMessage String?      @map("output_message")
  recipients    Json?        @default("[]") @map("recipients")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  userId        String       @map("user_id")

  user   User    @relation(fields: [userId], references: [id])
  events Event[]

  @@index([isActive])
  @@index([userId])
  @@map("workflows")
}

model Event {
  id           String      @id @default(cuid())
  title        String
  payload      Json
  status       EventStatus @default(OPEN)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  workflowId   String      @map("workflow_id")
  resolvedAt   DateTime?   @map("resolved_at")
  resolvedById String?     @map("resolved_by_id")

  workflow   Workflow      @relation(fields: [workflowId], references: [id])
  resolvedBy User?         @relation("ResolvedByUser", fields: [resolvedById], references: [id])
  comments   Comment[]
  snooze     Snooze?
  history    EventHistory[]

  @@index([status])
  @@index([workflowId])
  @@index([createdAt])
  @@index([resolvedById])
  @@index([status, createdAt])
  @@map("events")
}

model EventHistory {
  id        String      @id @default(cuid())
  action    EventAction
  createdAt DateTime    @default(now()) @map("created_at")
  eventId   String   @map("event_id")
  userId    String   @map("user_id")

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@map("event_history")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  eventId   String   @map("event_id")
  userId    String   @map("user_id")

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("comments")
}

model Snooze {
  id        String   @id @default(cuid())
  until     DateTime
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")
  eventId   String   @unique @map("event_id")
  userId    String   @map("user_id")

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([until])
  @@map("snoozes")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  userId    String           @map("user_id")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}
